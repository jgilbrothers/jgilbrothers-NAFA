# GEMINI_API_KEY: Optional for Gemini AI enhancements.
# Configure only if optional AI analysis is enabled.
# The app works offline without this value.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the static site URL.
# Used for self-referential links, local export links.
APP_URL="MY_APP_URL"

# APP_NAME: Customizable UI branding override (Vite client-exposed prefix)
VITE_APP_NAME="NAFA Ledger"

# APP_VERSION: App version (Vite client-exposed prefix)
VITE_APP_VERSION="1.0.0-OTA"
